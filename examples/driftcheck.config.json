{
  "ignorePaths": ["dist/**", "coverage/**", "fixtures/generated/**"],
  "languages": ["javascript", "typescript", "python", "rust"],
  "baselinePath": "driftcheck-baseline.json",
  "rules": {
    "DC001": {
      "enabled": true,
      "threshold": 0.62
    },
    "DC002": {
      "enabled": true,
      "severity": "warning"
    },
    "DC003": {
      "enabled": true,
      "severity": "info"
    }
  }
}
